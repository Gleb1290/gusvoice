# =============================================================================
# GusVoice — example environment. Copy to `.env` and fill in real values.
# NEVER commit a real .env (it is gitignored). This file holds placeholders only.
#
# For a turnkey install, run `./install.sh` — it generates all secrets and writes
# this file for you. Edit by hand only for advanced/custom setups.
#
# Generate strong secrets manually, e.g.:
#   openssl rand -hex 32
# =============================================================================

# ---- Base domain (turnkey) ------------------------------------------------
# Your domain; subdomains (or paths, in single-name mode) are derived from it.
#   e.g. BASE_DOMAIN=example.com  ->  voice/api/presence/lk/media/ntfy.example.com
BASE_DOMAIN=example.com
# ACME e-mail for Let's Encrypt when using the bundled Caddy (profile "caddy").
ACME_EMAIL=admin@example.com

# ---- Postgres -------------------------------------------------------------
POSTGRES_USER=gusvoice
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=gusvoice

# ---- App auth (backend JWT signing) --------------------------------------
JWT_SECRET=change-me-with-openssl-rand-hex-32

# ---- Super-admin ----------------------------------------------------------
# The single user (by username) granted full instance access + the admin panel.
# Leave empty to have no super-admin.
SUPERADMIN_USERNAME=
# First-boot bootstrap: if USERNAME + EMAIL + PASSWORD are ALL set, the backend seeds a PRE-VERIFIED
# super-admin on startup (idempotent — skipped if it already exists), so you log in immediately with no
# web signup / e-mail code. install.sh fills these in. Safe to blank PASSWORD after the first login.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Where operational alerts (brute-force lockouts) are emailed. Empty => logged only.
ADMIN_EMAIL=

# ---- Anti-bot registration -----------------------------------------------
# A bot that registers but never verifies otherwise squats the username forever. Abandoned
# unverified accounts with zero activity are purged after this many days (0 = never).
UNVERIFIED_TTL_DAYS=7
# Instance-wide signups per hour, on top of the per-IP limit. Caps IP-rotating botnets.
REGISTER_GLOBAL_MAX=100

# ---- Media storage (MinIO / S3) ------------------------------------------
# Holds avatars/attachments/sounds/icons in one public-read bucket. With the bundled
# MinIO (compose profile "storage") set MINIO_ENDPOINT=minio and MINIO_PUBLIC_URL to
# the public media host. Leave MINIO_ENDPOINT empty to disable uploads entirely.
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=gusvoice
# Base URL browsers load media from, e.g. https://media.example.com
MINIO_PUBLIC_URL=

# ---- Email verification (SMTP) -------------------------------------------
# Registration emails a 6-digit code via this SMTP server. Leave SMTP_HOST empty to
# disable email and log codes to the backend instead.
#   SMTP_SECURE=true for port 465 (implicit TLS); false for 587 (STARTTLS).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=change-me-smtp-password
MAIL_FROM=GusVoice <noreply@example.com>

# ---- Push notifications (UnifiedPush / self-hosted ntfy) ------------------
# DMs + @mentions wake the mobile app in the background via a self-hosted ntfy gateway
# (no Google/FCM). With the bundled ntfy (compose profile "push") point these at it.
# Leave NTFY_BASE_URL empty to disable push. NTFY_TOKEN is a write-only publish token.
#   e.g. NTFY_BASE_URL=https://ntfy.example.com
NTFY_BASE_URL=
NTFY_TOKEN=

# ---- Tauri updater feed (optional) ---------------------------------------
# Where /download reads the current desktop installer URL. For the public project the
# clients + updater live on GitHub Releases. Empty => /download returns 503.
UPDATE_FEED_URL=

# ---- LiveKit credentials --------------------------------------------------
# LIVEKIT_API_KEY is a key *name*, not a secret — it must match `webhook.api_key`
# in config/livekit.yaml. The secret below IS sensitive; generate a random one.
LIVEKIT_API_KEY=gusvoice
LIVEKIT_API_SECRET=change-me-with-openssl-rand-hex-32

# Internal URL is used by backend/presence to call the LiveKit API over the docker
# network. The EXTERNAL URL is handed to browsers for the wss:// signaling connection.
#   local dev : ws://localhost:7880
#   production: wss://lk.example.com
LIVEKIT_URL_EXTERNAL=ws://localhost:7880

# ---- Public client-facing URLs (consumed by the web client at runtime) ----
# Where the browser reaches the backend REST/WS, the presence WS, and (for the
# discovery doc) the push gateway. These are also served at /config.json so the
# generic desktop/mobile client can point itself at this instance.
#   local dev : http://localhost:4000  /  ws://localhost:4001
#   production: https://api.example.com  /  wss://presence.example.com
VITE_API_URL=http://localhost:4000
VITE_PRESENCE_WS=ws://localhost:4001
# Public ntfy base for the discovery doc (embedded push distributor). Usually same as NTFY_BASE_URL.
VITE_PUSH_GATEWAY=

# Allowed browser origin for CORS on the backend/presence services.
#   local dev : http://localhost:8080
#   production: https://voice.example.com
CLIENT_ORIGIN=http://localhost:8080

# ---- Image registry (CI / deploy) ----------------------------------------
# For local builds the defaults are fine. To deploy prebuilt images point these at
# a container registry, e.g. REGISTRY=ghcr.io/<owner>/gusvoice  TAG=latest
REGISTRY=gusvoice
TAG=local

# Host interface the reverse-proxied services bind to. Default 127.0.0.1 (local dev /
# proxy on the same host). Set 0.0.0.0 when the proxy runs on a different host.
BIND_ADDR=127.0.0.1
